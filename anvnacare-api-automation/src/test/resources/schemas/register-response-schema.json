{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegisterResponseSchema",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "user": {
      "type": "object",
      "properties": {
        "id": { "type": ["integer", "string"] },
        "name": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    }
  },
  "required": ["success", "message"]
}
